{
    "name": "Orchestrator-TSDHN Dev",

    "image": "ghcr.io/totallynotdavid/seismic-toolkit-dev:main",

    "workspaceFolder": "/app",
    "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind,consistency=cached",

    "hostRequirements": {
        "cpus": 4,
        "memory": "16gb",
        "storage": "32gb"
    },

    "remoteUser": "appuser",

    "forwardPorts": [8000],
    "portsAttributes": {
        "8000": {
            "label": "Orchestrator-TSDHN App",
            "onAutoForward": "notify"
        }
    },

    "postStartCommand": "sudo ln -s /lib/x86_64-linux-gnu/libgmt.so.6 /lib/x86_64-linux-gnu/libgmt.so",

    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/opt/venv/bin/python",
                "python.linting.pylintEnabled": true,
                "python.linting.enabled": true,
                "python.formatting.provider": "black",
                "python.formatting.blackPath": "/opt/venv/bin/black",
                "editor.formatOnSave": true,
                "[python]": {
                    "editor.codeActionsOnSave": {
                        "source.organizeImports": "always"
                    }
                },
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash"
                    }
                },
                "files.eol": "\n"
            },

            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylint",
                "ms-python.black-formatter",
                "redhat.vscode-yaml",
                "tamasfe.even-better-toml",
                "GitHub.copilot"
            ]
        }
    }
}
